[gd_resource type="Resource" script_class="ConditionResource" format=3 uid="uid://condition_grappled"]

[ext_resource type="Script" uid="uid://conditionrescript" path="res://data/conditions/ConditionResource.gd" id="1_cond"]

[resource]
script = ExtResource("1_cond")
resource_id = "condition_grappled"
effect_text = "A grappled creature’s speed becomes 0, and it can’t benefit from any bonus to its speed. The condition ends if the grappler is incapacitated. The condition also ends if an effect removes the grappled creature from the reach of the grappler or grappling effect, such as when a creature is hurled away by the thunderwave spell."
