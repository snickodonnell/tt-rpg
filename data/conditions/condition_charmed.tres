[gd_resource type="Resource" script_class="ConditionResource" format=3 uid="uid://condition_charmed"]

[ext_resource type="Script" uid="uid://conditionrescript" path="res://data/conditions/ConditionResource.gd" id="1_cond"]

[resource]
script = ExtResource("1_cond")
resource_id = "condition_charmed"
effect_text = "A charmed creature can’t attack the charmer or target the charmer with harmful abilities or magical effects. The charmer has advantage on any ability check to interact socially with the creature."
