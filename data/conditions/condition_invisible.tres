[gd_resource type="Resource" script_class="ConditionResource" format=3 uid="uid://condition_invisible"]

[ext_resource type="Script" uid="uid://conditionrescript" path="res://data/conditions/ConditionResource.gd" id="1_cond"]

[resource]
script = ExtResource("1_cond")
resource_id = "condition_invisible"
effect_text = "An invisible creature is impossible to see without the aid of magic or a special sense. For the purpose of hiding, the creature is heavily obscured. The creature’s location can be detected by any noise it makes or any tracks it leaves."
