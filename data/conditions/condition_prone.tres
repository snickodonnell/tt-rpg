[gd_resource type="Resource" script_class="ConditionResource" format=3 uid="uid://condition_prone"]

[ext_resource type="Script" uid="uid://conditionrescript" path="res://data/conditions/ConditionResource.gd" id="1_cond"]

[resource]
script = ExtResource("1_cond")
resource_id = "condition_prone"
effect_text = "A prone creature’s only movement option is to crawl, unless it stands up (costs half its movement). The creature has disadvantage on attack rolls. An attack roll against the creature has advantage if the attacker is within 5 feet of the creature. Otherwise, the attack roll has disadvantage."
